# ──────────────────────────────────────────────────────────────────────────
#  NEVER commit private key material or local secrets.
#  Private keys live in $AGENT_TEAM_SECRETS (default ~/.config/agent-team),
#  OUTSIDE this repo. These patterns are belt-and-suspenders in case a key
#  ever lands in the working tree.
# ──────────────────────────────────────────────────────────────────────────

# Managed access key directory (if ever placed inside the repo)
keys/
secrets/
*.secret

# Any SSH/TLS PRIVATE keys (note: *.pub public keys are intentionally allowed)
*_ed25519
*_rsa
*_ecdsa
*_dsa
id_ed25519
id_rsa
id_ecdsa
*.pem
*.key
*.p12
*.pfx

# Things that should stay machine-local, not shared
known_hosts
*.local

# macOS / editor noise
.DS_Store
._*
*.swp
*~
.idea/
.vscode/
